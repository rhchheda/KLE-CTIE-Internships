// "2026-07-17" / "10:00" (IST, 24h, as stored) -> "17 Jul 2026" / "10:00 AM"
// for human-readable display in emails.
function fmtDateNice_(iso) {
  var d = new Date(String(iso || '') + 'T00:00:00');
  if (isNaN(d.getTime())) return String(iso || '');
  return Utilities.formatDate(d, TZ, 'dd MMM yyyy');
}
function fmtTimeNice_(hhmm) {
  var p = String(hhmm || '').split(':');
  if (p.length < 2) return String(hhmm || '');
  var h = parseInt(p[0], 10), m = p[1];
  if (isNaN(h)) return String(hhmm || '');
  var ampm = h >= 12 ? 'PM' : 'AM';
  var h12  = h % 12; if (h12 === 0) h12 = 12;
  return h12 + ':' + m + ' ' + ampm;
}

// Convenience: two-column info row for email tables
function tr_(label, value) {
  return '<tr>'
    + '<td style="padding:5px 10px 5px 0;color:#888;font-size:12px;white-space:nowrap">'
    + label + '</td>'
    + '<td style="padding:5px 0;color:#1a1a2e;font-size:12px;font-weight:700">'
    + String(value || '') + '</td>'
    + '</tr>';
}

