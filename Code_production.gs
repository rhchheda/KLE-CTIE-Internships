  return '<tr><td style="padding:5px 10px 5px 0;color:#888;font-size:12px">Link</td>'
    + '<td style="padding:5px 0;font-size:12px">'
    + '<a href="' + value + '" style="color:#1565C0">' + value + '</a></td></tr>';
