// ?? COMPLETE INTERNSHIP ???????????????????????????????????????
function completeInternship(token, appId, completion) {
  try {
    var startupId = resolveSession_(token, 'startup');
    if (!startupId) return { ok: false, msg: 'Session expired. Please log in again.' };
    var row = findApp_(appId);
    if (!row) return { ok: false, msg: 'Application not found.' };
    if (String(row.data[row.col['Startup_ID']] || '') !== startupId)
      return { ok: false, msg: 'Not authorised.' };
    if (String(row.data[row.col['Status']] || '') !== 'Selected')
      return { ok: false, msg: 'Can only complete internships in Selected status.' };

    var endDate  = completion.endDate  || today_();
    var rating   = Math.max(1, Math.min(5, parseInt(completion.rating || 5)));
    var feedback = (completion.feedback || '').trim();
    var intId    = String(row.data[row.col['Internship_ID']] || '');
    var role     = completion.role || getRoleTitle_(intId) || 'Intern';
    var start    = cellStr_(row.data[row.col['Intern_Start']]);

    // Certificate eligibility -- enough progress must actually be on record
    // before we issue a "verified" certificate. Thresholds live in CONFIG,
    // not hardcoded, so admin can tune them without a code change.
    var durationWeeks = parseInt(getInternshipField_(intId, 'Duration_Weeks')) || 12;
    var stats          = getProgressStats_(appId, durationWeeks);
    var minWeeksPct     = getConfigValue_('min_weeks_logged_pct', 70);
    var minAttendancePct= getConfigValue_('min_attendance_pct', 75);
    if (stats.weeksLoggedPct < minWeeksPct)
      return { ok: false, msg: 'Only ' + stats.weeksLogged + ' of ' + durationWeeks
        + ' expected weeks (' + Math.round(stats.weeksLoggedPct) + '%) have been logged -- '
        + 'a certificate requires at least ' + minWeeksPct + '%. Log the missing weeks first, '
        + 'or contact CTIE for an exception.' };
    if (stats.attendancePct < minAttendancePct)
      return { ok: false, msg: 'Logged attendance is ' + Math.round(stats.attendancePct) + '%, '
        + 'below the ' + minAttendancePct + '% required for a certificate. Contact CTIE for an exception.' };

    updateAppFields_(row, {
      Completion_Status: 'Completed',
      Intern_End:        endDate,
      Status:            'Completed',
      Startup_Rating:    String(rating),
      Startup_Feedback:  feedback,
      Last_Updated:      now_()
    });

    var sName  = String(row.data[row.col['Student_Name']]    || '');
    var stName = String(row.data[row.col['Startup_Name']]    || '');
    var instE  = String(row.data[row.col['Institute_Email']] || '');
    var persE  = String(row.data[row.col['Personal_Email']]  || '');

    var cert     = buildCertHtml_(sName, stName, intId, start, endDate, role, rating);
    var trackUrl = execUrl_() + '?page=Track&appId=' + appId;
    var subject  = 'Internship completed -- your certificate is ready | ' + stName;
    var body     = buildCertReadyHtml_(sName, stName, trackUrl);
    sendEmail_(instE, subject, body);
    if (persE !== instE) sendEmail_(persE, subject, body);
    sendEmail_(ADMIN_EMAIL,
      '[CTIE Portal] Internship completed: ' + appId,
      sName + ' completed internship with ' + stName + '. Rating: ' + rating + '/5.');

    return { ok: true, html: buildCertPage_(cert),
      msg: 'Internship marked complete. Certificate is ready to view/print.' };
  } catch(e) { return { ok: false, msg: e.message }; }
}

// Regenerates the certificate on demand for a completed application --
// callable from the student's own tracking page (Application ID acts as
// the bearer credential here, same as getApplicationStatus()).
function getCertificate(appId) {
  try {
    var row = findApp_(appId);
    if (!row) return { ok: false, msg: 'Application not found.' };
    if (String(row.data[row.col['Completion_Status']] || '') !== 'Completed')
      return { ok: false, msg: 'Certificate not available -- internship is not yet marked complete.' };

    var intId  = String(row.data[row.col['Internship_ID']]  || '');
    var cert = buildCertHtml_(
      String(row.data[row.col['Student_Name']] || ''),
      String(row.data[row.col['Startup_Name']] || ''),
      intId,
      cellStr_(row.data[row.col['Intern_Start']]),
      cellStr_(row.data[row.col['Intern_End']]),
      getRoleTitle_(intId) || 'Intern',
      parseInt(row.data[row.col['Startup_Rating']]) || 5
    );
    return { ok: true, html: buildCertPage_(cert) };
  } catch(e) { return { ok: false, msg: e.message }; }
}

