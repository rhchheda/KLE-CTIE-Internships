// Weeks-logged % and attendance % for one application, from its PROGRESS
// rows -- used to gate certificate issuance in completeInternship().
function getProgressStats_(appId, durationWeeks) {
  var result = { weeksLogged: 0, weeksLoggedPct: 100, attendancePct: 100 };
  try {
    var sheet = sh_('PROGRESS');
    if (!sheet || sheet.getLastRow() < 2) return result;
    var data = sheet.getDataRange().getValues();
    var col  = cols_(data[0]);
    var weeksSeen = {};
    var daysPresent = 0, daysTotal = 0;
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][col['App_ID']] || '') !== appId) continue;
      weeksSeen[String(data[i][col['Week']] || '')] = true;
      daysPresent += Number(data[i][col['Days_Present']]) || 0;
      daysTotal   += Number(data[i][col['Days_Total']])   || 0;
    }
    result.weeksLogged    = Object.keys(weeksSeen).length;
    result.weeksLoggedPct = durationWeeks > 0 ? (result.weeksLogged / durationWeeks) * 100 : 100;
    result.attendancePct  = daysTotal > 0 ? (daysPresent / daysTotal) * 100 : 100;
    return result;
  } catch(e) { return result; }
}

function notifyStartup_(startupId, subject, bodyText) {
  try {
    var sheet = sh_('STARTUPS');
    var data  = sheet.getDataRange().getValues();
    var col   = cols_(data[0]);
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][col['Startup_ID']] || '') !== startupId) continue;
      var email = String(data[i][col['Contact_Email']] || '');
      if (email) {
        var portalLink = execUrl_() + '?page=StartupPortal';
        sendEmail_(email, subject,
          '<p>' + bodyText + '</p>'
          + '<p style="margin-top:14px"><a href="' + portalLink
          + '" style="background:#C8973A;color:#0B1F3A;padding:10px 20px;'
          + 'border-radius:7px;text-decoration:none;font-weight:700">Log in to portal</a></p>');
      }
      return;
    }
  } catch(e) { Logger.log('notifyStartup_ error: ' + e.message); }
}

function syncInternKPI_() {
  // Sync completed internship count to TBI main sheet if configured
  try {
    var props    = PropertiesService.getScriptProperties();
    var tbiSheet = props.getProperty('TBI_SHEET_ID') || '';
    if (!tbiSheet) return;
    var ss  = SpreadsheetApp.openById(tbiSheet);
    var cfg = ss.getSheetByName('CONFIG');
    if (!cfg) return;
    var data = cfg.getDataRange().getValues();
    for (var i = 0; i < data.length; i++) {
      if (String(data[i][0] || '') === 'intern_confirmed_count') {
        cfg.getRange(i + 1, 2).setValue(parseInt(data[i][1] || 0) + 1);
        SpreadsheetApp.flush();
        return;
      }
    }
    // Key not found -- create it
    cfg.appendRow(['intern_confirmed_count', 1]);
    SpreadsheetApp.flush();
  } catch(e) { Logger.log('syncInternKPI_ skipped: ' + e.message); }
}

