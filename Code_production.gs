// ── GET STARTUP DASHBOARD (stats + pending actions in one call) ──
function getStartupDashboard(token) {
  try {
    var startupId = resolveSession_(token, 'startup');
    if (!startupId) return { ok: false, msg: 'Session expired. Please log in again.' };
    // Applications for this startup
    var appSheet = sh_('APPLICATIONS');
    var apps = [];
    if (appSheet && appSheet.getLastRow() > 1) {
      var appData  = appSheet.getDataRange().getValues();
      var appHeads = appData[0];
      var appCol   = cols_(appHeads);
      apps = appData.slice(1).filter(function(row) {
        return String(row[appCol['Startup_ID']] || '') === startupId;
      }).map(function(row) {
        var obj = {};
        appHeads.forEach(function(h, i) { obj[h] = row[i]; });
        return obj;
      });
    }

    // Internships for this startup
    var intSheet = sh_('INTERNSHIPS');
    var roles = [];
    if (intSheet && intSheet.getLastRow() > 1) {
      var intData  = intSheet.getDataRange().getValues();
      var intHeads = intData[0];
      var intCol   = cols_(intHeads);
      roles = intData.slice(1).filter(function(row) {
        return String(row[intCol['Startup_ID']] || '') === startupId;
      }).map(function(row) {
        var obj = {};
        intHeads.forEach(function(h, i) { obj[h] = row[i]; });
        return obj;
      });
    }

    // Stats
    var openRoles   = roles.filter(function(r){ return r.Status === 'Open'; }).length;
    var totalApps   = apps.length;
    var shortlisted = apps.filter(function(a){ return a.Status === 'Shortlisted'; }).length;
    var active      = apps.filter(function(a){ return a.Status === 'Selected'; }).length;
    var completed   = apps.filter(function(a){ return a.Status === 'Completed'; }).length;

    // Pending actions needing attention
    var pending = [];
    apps.filter(function(a){ return a.Status === 'Applied'; })
      .forEach(function(a) {
        var daysOld = (Date.now() - new Date(String(a.Applied_At||'')).getTime()) / 86400000;
        if (daysOld > 3) pending.push({
          type: 'review', appId: a.App_ID,
          text: 'Review application from ' + a.Student_Name,
          urgent: daysOld > 6
        });
      });
    apps.filter(function(a){ return a.Status === 'Interview Held -- Outcome Pending'; })
      .forEach(function(a) { pending.push({
        type: 'outcome', appId: a.App_ID,
        text: 'Enter outcome for ' + a.Student_Name, urgent: true
      }); });
    apps.filter(function(a){ return a.Status === 'Shortlisted'; })
      .forEach(function(a) { pending.push({
        type: 'schedule', appId: a.App_ID,
        text: 'Schedule interview for ' + a.Student_Name, urgent: false
      }); });

    return jsonSafe_({
      ok: true,
      stats: { openRoles: openRoles, totalApps: totalApps,
               shortlisted: shortlisted, active: active, completed: completed },
      applications: apps,
      internships:  roles,
      pending:      pending
    });
  } catch(e) {
    Logger.log('getStartupDashboard error: ' + e.message);
    return { ok: false, msg: e.message };
  }
}


