// ── ADMIN REPORTS ─────────────────────────────────────────────
// Returns all data needed for the HTML reports page in one call
function getAdminReports(token, filters) {
  try {
    if (!resolveSession_(token, 'admin')) return { ok: false, msg: 'Session expired. Please log in again.' };
    var f       = filters || {};
    var fromMs  = f.from  ? new Date(f.from).getTime()  : 0;
    var toMs    = f.to    ? new Date(f.to).getTime()    : Date.now();

    // ── Load APPLICATIONS ─────────────────────────────────────
    var appSheet = sh_('APPLICATIONS');
    var apps     = [];
    if (appSheet && appSheet.getLastRow() > 1) {
      var aData  = appSheet.getDataRange().getValues();
      var aHeads = aData[0];
      var aCol   = cols_(aHeads);
      apps = aData.slice(1).map(function(row) {
        var obj = {};
        aHeads.forEach(function(h,i){ obj[h] = row[i]; });
        return obj;
      }).filter(function(a) {
        var t = new Date(String(a.Applied_At||'')).getTime();
        var matchDate       = (!fromMs || t >= fromMs) && t <= toMs;
        var matchStatus     = !f.status     || a.Status         === f.status;
        var matchStartup    = !f.startup    || a.Startup_ID     === f.startup;
        var matchInstitute  = !f.institute  || a.Institute_Name === f.institute;
        var matchDepartment = !f.department || a.Course         === f.department;
        return matchDate && matchStatus && matchStartup && matchInstitute && matchDepartment;
      });
    }

    // ── Load INTERNSHIPS ──────────────────────────────────────
    var intSheet = sh_('INTERNSHIPS');
    var roles    = [];
    if (intSheet && intSheet.getLastRow() > 1) {
      var iData  = intSheet.getDataRange().getValues();
      var iHeads = iData[0];
      var iCol   = cols_(iHeads);
      roles = iData.slice(1).map(function(row) {
        var obj = {};
        iHeads.forEach(function(h,i){ obj[h] = row[i]; });
        return obj;
      }).filter(function(r) {
        return !f.startup || r.Startup_ID === f.startup;
      });
    }

    // ── Load STARTUPS ─────────────────────────────────────────
    var stSheet  = sh_('STARTUPS');
    var startups = [];
    if (stSheet && stSheet.getLastRow() > 1) {
      var sData  = stSheet.getDataRange().getValues();
      var sHeads = sData[0];
      startups = sData.slice(1).map(function(row) {
        var obj = {};
        sHeads.forEach(function(h,i){ obj[h] = row[i]; });
        return obj;
      });
    }

    // ── Load PROGRESS ─────────────────────────────────────────
    var progSheet = sh_('PROGRESS');
    var logs      = [];
    if (progSheet && progSheet.getLastRow() > 1) {
      var pData  = progSheet.getDataRange().getValues();
      var pHeads = pData[0];
      logs = pData.slice(1).map(function(row) {
        var obj = {};
        pHeads.forEach(function(h,i){ obj[h] = row[i]; });
        return obj;
      });
    }

    // ── Compute summary stats ─────────────────────────────────
    var statuses   = {};
    var sectorMap  = {};
    var startupMap = {};
    var monthMap   = {};

    apps.forEach(function(a) {
      var st = String(a.Status||'Other');
      statuses[st] = (statuses[st]||0) + 1;

      var sid = String(a.Startup_ID||'');
      if (!startupMap[sid]) startupMap[sid] = {
        name: String(a.Startup_Name||sid), apps:0, shortlisted:0,
        selected:0, completed:0, rescheduleLimit:0
      };
      startupMap[sid].apps++;
      if (st==='Shortlisted'||['Interview Scheduled','Interview Held -- Outcome Pending',
          'Offer Pending OTP','Selected','Completed'].indexOf(st)>=0)
        startupMap[sid].shortlisted++;
      if (st==='Selected'||st==='Completed') startupMap[sid].selected++;
      if (st==='Completed') startupMap[sid].completed++;
      if (st==='Closed -- Reschedule Limit') startupMap[sid].rescheduleLimit++;

      var mo = String(a.Applied_At||'').substring(3,11); // MMM-YYYY
      monthMap[mo] = (monthMap[mo]||0) + 1;
    });

    roles.forEach(function(r) {
      var sec = String(r.Department||'Other');
      if (!sectorMap[sec]) sectorMap[sec] = {roles:0, positions:0, filled:0, stipend:0, academic:0};
      sectorMap[sec].roles++;
      sectorMap[sec].positions += parseInt(r.Positions_Available||0);
      sectorMap[sec].filled    += parseInt(r.Positions_Filled   ||0);
      if (parseFloat(r.Stipend_INR||0)>0) sectorMap[sec].stipend++;
      else sectorMap[sec].academic++;
    });

    // SLA violations
    var slaViolations = apps.filter(function(a) {
      return String(a.Status||'').indexOf('Closed')>=0 &&
             String(a.Notes||'').indexOf('Auto-closed')>=0;
    });

    return jsonSafe_({
      ok: true,
      summary: {
        totalApps:       apps.length,
        totalRoles:      roles.length,
        totalStartups:   startups.length,
        completed:       statuses['Completed']||0,
        selected:        statuses['Selected']||0,
        active:          (statuses['Selected']||0),
        slaViolations:   slaViolations.length,
        fillRate:        roles.length
          ? Math.round((roles.reduce(function(a,r){return a+parseInt(r.Positions_Filled||0);},0)
            / roles.reduce(function(a,r){return a+parseInt(r.Positions_Available||1);},0))*100)
          : 0
      },
      statuses:    statuses,
      sectorMap:   sectorMap,
      startupMap:  startupMap,
      monthMap:    monthMap,
      applications:apps,
      roles:       roles,
      startups:    startups,
      slaViolations:slaViolations
    });
  } catch(e) {
    Logger.log('getAdminReports error: ' + e.message);
    return { ok:false, msg:e.message };
  }
}

