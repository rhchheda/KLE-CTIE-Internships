// ── ADD STARTUP (admin) ───────────────────────────────────────
// Admin enters an already-vetted (incubated) startup's details directly --
// no self-registration/approval queue, since admin entry itself is the
// approval. PIN stays blank; the startup sets it on first login, same as
// the existing flow.
// Outreach email to a prospective startup CTIE wants to invite -- distinct
// from addStartup(): no Startup_ID, no PIN, no STARTUPS row at all. Purely
// a benefits pitch with a "get in touch" CTA; onboarding still happens
// later through the normal Add Startup flow once they say yes.
function sendStartupInvitation(token, data) {
  try {
    if (!resolveSession_(token, 'admin')) return { ok: false, msg: 'Session expired. Please log in again.' };

    var name  = String(data.name || '').trim();
    var email = String(data.contactEmail || '').trim().toLowerCase();
    if (!name) return { ok: false, msg: 'Startup name is required.' };
    if (!email || email.indexOf('@') < 0) return { ok: false, msg: 'Valid contact email required.' };

    var contactName = String(data.contactName || '').trim();
    sendEmail_(email,
      'Partner with KLE-CTIE -- bring your next intern from our student pipeline',
      buildStartupInviteHtml_(name, contactName));

    Logger.log('Startup invitation sent to ' + email + ' (' + name + ')');
    return { ok: true, msg: 'Invitation sent to ' + email + '.' };
  } catch(e) {
    Logger.log('sendStartupInvitation error: ' + e.message);
    return { ok: false, msg: e.message };
  }
}

function addStartup(token, data) {
  try {
    if (!resolveSession_(token, 'admin')) return { ok: false, msg: 'Session expired. Please log in again.' };

    var required = ['name', 'contactEmail', 'sector'];
    for (var r = 0; r < required.length; r++) {
      if (!data[required[r]] || !String(data[required[r]]).trim())
        return { ok: false, msg: 'Required field missing: ' + required[r] };
    }
    var contactEmail = String(data.contactEmail).trim().toLowerCase();
    if (contactEmail.indexOf('@') < 0)
      return { ok: false, msg: 'Valid contact email required.' };
    if (!isValidName_(data.name))
      return { ok: false, msg: 'Enter the startup name using letters only (no numbers or symbols).' };
    if (data.opcName && !isValidName_(data.opcName))
      return { ok: false, msg: 'Enter the OPC name using letters only (no numbers or symbols).' };
    var startupNameClean = toProperCase_(data.name);
    var opcNameClean      = data.opcName ? toProperCase_(data.opcName) : '';

    var sheet = sh_('STARTUPS');
    if (!sheet) return { ok: false, msg: 'System not initialised. Run setupSheets().' };

    // Duplicate check -- same contact email OR same startup name (case-insensitive)
    var existing = sheet.getDataRange().getValues();
    var col      = cols_(existing[0]);
    for (var i = 1; i < existing.length; i++) {
      if (String(existing[i][col['Contact_Email']] || '').toLowerCase() === contactEmail)
        return { ok: false, msg: 'A startup with this contact email already exists.' };
      if (String(existing[i][col['Startup_Name']] || '').toLowerCase() === startupNameClean.toLowerCase())
        return { ok: false, msg: 'A startup named "' + startupNameClean + '" already exists.' };
    }

    var count      = Math.max(sheet.getLastRow(), 1);
    var startupId  = 'CTIE-' + new Date().getFullYear() + '-' + ('000' + count).slice(-3);

    sheet.appendRow([
      startupId,
      startupNameClean,
      contactEmail,
      '', '',                             // PIN_Hash, PIN_Salt -- set on first login
      data.sector,
      data.stage        || '',
      data.foundedYear  || '',
      data.about        || '',
      data.website      || '',
      data.linkedin     || '',
      opcNameClean,
      data.opcEmail     || '',
      data.opcPhone     || '',
      'TRUE',                             // Active
      now_(),                             // Registered_At
      '',                                 // Last_Login
      0, 0, 0,                             // Total_Posted, Total_Selected, Reschedule_Strikes
      data.logoUrl      || ''
    ]);
    SpreadsheetApp.flush();

    var portalUrl = execUrl_() + '?page=StartupPortal';
    sendEmail_(contactEmail,
      'Welcome to KLE-CTIE Internship Portal -- your Startup ID',
      buildStartupWelcomeHtml_(startupNameClean, startupId, portalUrl));

    Logger.log('Startup added: ' + startupId + ' (' + startupNameClean + ')');
    return { ok: true, startupId: startupId, msg: 'Startup added. Login details emailed to ' + contactEmail + '.' };
  } catch(e) {
    Logger.log('addStartup error: ' + e.message);
    return { ok: false, msg: e.message };
  }
}

