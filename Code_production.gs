function setupTriggers() {
  // Remove all existing triggers to avoid duplicates
  ScriptApp.getProjectTriggers().forEach(function(t) {
    ScriptApp.deleteTrigger(t);
  });

  // 8 AM -- daily SLA check (review + schedule enforcement)
  ScriptApp.newTrigger('dailySLACheck')
    .timeBased().atHour(8).everyDays(1).inTimezone(TZ).create();

  // 10 AM -- outcome window check (post-interview 48h enforcement)
  ScriptApp.newTrigger('outcomeCheckMorning')
    .timeBased().atHour(10).everyDays(1).inTimezone(TZ).create();

  // 6 PM -- second outcome check (catches afternoon interviews)
  ScriptApp.newTrigger('outcomeCheckEvening')
    .timeBased().atHour(18).everyDays(1).inTimezone(TZ).create();

  Logger.log('Triggers installed: dailySLACheck @ 8AM, outcomeCheck @ 10AM + 6PM');
  return { ok: true, msg: '3 daily triggers installed.' };
}

// ?? STARTUP AUTH ??????????????????????????????????????????????
function startupLogin(startupId, pin) {
  try {
    if (!pin || pin.length < 4 || !/^\d+$/.test(pin))
      return { ok: false, msg: 'PIN must be at least 4 digits.' };

    var lockKey = 'startup_' + String(startupId || '').toLowerCase();
    var lockMsg = checkLoginLockout_(lockKey);
    if (lockMsg) return { ok: false, msg: lockMsg };

    var sheet = sh_('STARTUPS');
    if (!sheet) return { ok: false, msg: 'System not initialised. Run setupSheets().' };
    var data  = sheet.getDataRange().getValues();
    var heads = data[0];
    var col   = cols_(heads);

    for (var i = 1; i < data.length; i++) {
      if (String(data[i][col['Startup_ID']] || '').toLowerCase()
          !== startupId.toLowerCase()) continue;

      if (String(data[i][col['Active']] || '').toUpperCase() !== 'TRUE')
        return { ok: false, msg: 'Account is not active. Contact CTIE admin.' };

      var stored = String(data[i][col['PIN_Hash']] || '');
      var salt   = String(data[i][col['PIN_Salt']] || '');

      if (!stored) {
        // First login -- set PIN
        var newSalt = tok_().slice(0, 32);
        var newHash = hash_(pin, newSalt);
        sheet.getRange(i + 1, col['PIN_Hash'] + 1).setValue(newHash);
        sheet.getRange(i + 1, col['PIN_Salt'] + 1).setValue(newSalt);
        sheet.getRange(i + 1, col['Last_Login'] + 1).setValue(now_());
        SpreadsheetApp.flush();
        clearLoginLockout_(lockKey);
        return {
          ok:        true,
          token:     createSession_('startup', startupId),
          startupId: startupId,
          name:      String(data[i][col['Startup_Name']] || ''),
          isFirst:   true,
          msg:       'PIN set. Welcome to KLE-CTIE Internship Portal.'
        };
      }

      if (hash_(pin, salt) !== stored) {
        var remaining = recordLoginFailure_(lockKey);
        return { ok: false, msg: remaining > 0
          ? 'Incorrect PIN. ' + remaining + ' attempt' + (remaining === 1 ? '' : 's') + ' remaining before temporary lockout.'
          : 'Too many incorrect attempts. Locked for ' + LOGIN_LOCKOUT_MINUTES + ' minutes.' };
      }

      sheet.getRange(i + 1, col['Last_Login'] + 1).setValue(now_());
      SpreadsheetApp.flush();
      clearLoginLockout_(lockKey);
      return {
        ok:        true,
        token:     createSession_('startup', startupId),
        startupId: startupId,
        name:      String(data[i][col['Startup_Name']] || ''),
        sector:    String(data[i][col['Sector']] || ''),
        stage:     String(data[i][col['Stage']]  || ''),
        website:   String(data[i][col['Website_URL']] || ''),
        msg:       'Welcome back.'
      };
    }
    return { ok: false, msg: 'Startup ID not found. Contact CTIE admin.' };
  } catch(e) {
    Logger.log('startupLogin error: ' + e.message);
    return { ok: false, msg: 'Login error: ' + e.message };
  }
}

