// ?? RESUME UPLOAD ?????????????????????????????????????????????
var RESUME_ALLOWED_MIME = [
  'application/pdf',
  'application/msword',
  'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
];
var RESUME_MAX_BYTES = 5 * 1024 * 1024; // 5MB

// Public/unauthenticated by design (called during student application submission),
// so it's abuse-resistant rather than session-gated: type + size limits only.
function uploadResume(base64Data, fileName, mimeType) {
  try {
    if (RESUME_ALLOWED_MIME.indexOf(mimeType) < 0)
      return { ok: false, msg: 'Only PDF, DOC, or DOCX resumes are accepted.' };

    var bytes = Utilities.base64Decode(base64Data);
    if (bytes.length > RESUME_MAX_BYTES)
      return { ok: false, msg: 'Resume file is too large (max 5MB).' };

    var folder = getYearResumeFolder_();
    var blob = Utilities.newBlob(bytes, mimeType, fileName);
    var file = folder.createFile(blob);
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
    Logger.log('Resume uploaded: ' + file.getId());
    return { ok: true, url: file.getUrl(), id: file.getId() };
  } catch(e) { return { ok: false, msg: e.message }; }
}

// Resumes are organised as RESUME_FOLDER_ID / <year> / <files>, auto-created
// on first use each year so nobody has to remember to make a new folder.
function getYearResumeFolder_() {
  var props    = PropertiesService.getScriptProperties();
  var folderId = props.getProperty('RESUME_FOLDER_ID') || '';
  var root     = folderId ? DriveApp.getFolderById(folderId) : DriveApp.getRootFolder();
  var year     = String(new Date().getFullYear());
  var existing = root.getFoldersByName(year);
  if (existing.hasNext()) return existing.next();
  return root.createFolder(year);
}

var MIME_EXT_MAP_ = {
  'application/pdf': 'pdf',
  'application/msword': 'doc',
  'application/vnd.openxmlformats-officedocument.wordprocessingml.document': 'docx'
};

// Safe, readable filename fragment: letters/digits/spaces only, spaces -> underscores.
function sanitizeFilePart_(s) {
  return String(s || '').replace(/[^a-zA-Z0-9 ]/g, '').trim().replace(/\s+/g, '_');
}

// Renames a just-uploaded resume to "<App_ID>_<Student_Name>.<ext>" so anyone
// browsing the Drive folder can identify a file without opening it.
function renameResumeFile_(fileId, appId, studentName, mimeType) {
  try {
    var ext = MIME_EXT_MAP_[mimeType] || 'pdf';
    var name = sanitizeFilePart_(appId) + '_' + sanitizeFilePart_(studentName) + '.' + ext;
    DriveApp.getFileById(fileId).setName(name);
  } catch(e) { Logger.log('renameResumeFile_ error: ' + e.message); }
}

// Statuses where re-uploading a resume still makes sense. Once an
// application is decided (selected/not selected/completed/closed), a new
// resume wouldn't change anything, so we stop accepting updates there.
var RESUME_UPDATE_STATUSES = [
  'Applied', 'Shortlisted', 'Interview Scheduled',
  'Interview Held -- Outcome Pending', 'Offer Pending OTP'
];

// Student-facing, public/unauthenticated by design (same trust model as
// getApplicationStatus -- knowing the App_ID is the access check), called
// from the Track page to replace an already-submitted resume.
function updateResume(appId, base64Data, fileName, mimeType) {
  try {
    var row = findApp_(appId);
    if (!row) return { ok: false, msg: 'Application not found.' };

    var status = String(row.data[row.col['Status']] || '');
    if (RESUME_UPDATE_STATUSES.indexOf(status) < 0)
      return { ok: false, msg: 'This application is past the stage where a resume update is useful.' };

    if (RESUME_ALLOWED_MIME.indexOf(mimeType) < 0)
      return { ok: false, msg: 'Only PDF, DOC, or DOCX resumes are accepted.' };
    var bytes = Utilities.base64Decode(base64Data);
    if (bytes.length > RESUME_MAX_BYTES)
      return { ok: false, msg: 'Resume file is too large (max 5MB).' };

    var studentName = String(row.data[row.col['Student_Name']] || '');
    var ext  = MIME_EXT_MAP_[mimeType] || 'pdf';
    var name = sanitizeFilePart_(appId) + '_' + sanitizeFilePart_(studentName) + '.' + ext;

    var folder = getYearResumeFolder_();
    var blob   = Utilities.newBlob(bytes, mimeType, name);
    var file   = folder.createFile(blob);
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);

    // Trash (not permanently delete) the previous file, if any.
    var oldFileId = String(row.data[row.col['Resume_File_ID']] || '');
    if (oldFileId) {
      try { DriveApp.getFileById(oldFileId).setTrashed(true); }
      catch(e) { Logger.log('Could not trash old resume ' + oldFileId + ': ' + e.message); }
    }

    updateAppFields_(row, {
      Resume_URL:        file.getUrl(),
      Resume_File_ID:    file.getId(),
      Resume_Updated_At: now_(),
      Last_Updated:      now_()
    });

    Logger.log('Resume updated for ' + appId + ': ' + file.getId());
    return { ok: true, url: file.getUrl(), msg: 'Resume updated successfully.' };
  } catch(e) {
    Logger.log('updateResume error: ' + e.message);
    return { ok: false, msg: e.message };
  }
}

