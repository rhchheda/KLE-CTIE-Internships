// ?? SCHEDULE INTERVIEW ????????????????????????????????????????
function scheduleInterview(token, appId, slot) {
  try {
    var startupId = resolveSession_(token, 'startup');
    if (!startupId) return { ok: false, msg: 'Session expired. Please log in again.' };
    if (!slot || !slot.date || !slot.time)
      return { ok: false, msg: 'Date and time are required.' };
    if (slot.mode === 'In-person' && !String(slot.meetLink || '').trim())
      return { ok: false, msg: 'Venue / address is required for an in-person interview.' };

    var row = findApp_(appId);
    if (!row) return { ok: false, msg: 'Application not found.' };
    if (String(row.data[row.col['Startup_ID']] || '') !== startupId)
      return { ok: false, msg: 'Not authorised.' };

    var status  = String(row.data[row.col['Status']] || '');
    var rCount  = parseInt(row.data[row.col['Reschedule_Count']] || '0');
    var isFirst = (status === 'Shortlisted');
    var isRescheduling = (status === 'Interview Scheduled');

    // On reschedule: check + increment counter
    if (isRescheduling) {
      rCount++;
      if (rCount > MAX_RESCHEDULES) {
        // Block -- limit exhausted
        updateAppFields_(row, {
          Status:       'Closed -- Reschedule Limit',
          Notes:        'Auto-closed: reschedule limit (' + MAX_RESCHEDULES + ') reached on ' + today_(),
          Last_Updated: now_()
        });
        var instE  = String(row.data[row.col['Institute_Email']] || '');
        var persE  = String(row.data[row.col['Personal_Email']]  || '');
        var sName  = String(row.data[row.col['Student_Name']]    || '');
        var stName = String(row.data[row.col['Startup_Name']]    || '');
        var body   = buildRescheduleLimitHtml_(sName, stName, MAX_RESCHEDULES);
        sendEmail_(instE, 'Application closed -- reschedule limit reached', body);
        if (persE !== instE) sendEmail_(persE, 'Application closed -- reschedule limit reached', body);
        sendEmail_(ADMIN_EMAIL,
          '[CTIE Alert] Reschedule limit hit: ' + appId,
          'Application ' + appId + ' closed. ' + startupId + ' exhausted '
          + MAX_RESCHEDULES + ' reschedules. Consider a conversation with this startup.');
        return { ok: false, msg: 'Reschedule limit (' + MAX_RESCHEDULES + ') reached. Application closed.' };
      }
    }

    // Write to the correct slot column (slot 1=first schedule, 2=first reschedule, 3=second reschedule)
    var slotIndex  = isFirst ? 1 : rCount + 1;
    var slotPrefix = 'Interview_' + slotIndex + '_';
    var updates    = {
      Status:                  'Interview Scheduled',
      Reschedule_Count:        String(rCount),
      Active_Interview_Slot:   String(slotIndex),
      Last_Updated:            now_()
    };
    updates[slotPrefix + 'Date'] = slot.date;
    updates[slotPrefix + 'Time'] = slot.time;
    updates[slotPrefix + 'Mode'] = slot.mode || 'Online';
    updates[slotPrefix + 'Link'] = slot.meetLink || '';
    updateAppFields_(row, updates);

    // Notify student
    var instE    = String(row.data[row.col['Institute_Email']] || '');
    var persE    = String(row.data[row.col['Personal_Email']]  || '');
    var sName    = String(row.data[row.col['Student_Name']]    || '');
    var stName   = String(row.data[row.col['Startup_Name']]    || '');
    var isFinal  = (rCount === MAX_RESCHEDULES);
    var label    = isRescheduling ? 'Interview rescheduled' : 'Interview scheduled';
    var subject  = label + ' -- ' + fmtDateNice_(slot.date) + ' at ' + fmtTimeNice_(slot.time) + ' | ' + stName;
    var body     = buildInterviewHtml_(sName, stName, slot, rCount, MAX_RESCHEDULES);
    sendEmail_(instE, subject, body);
    if (persE !== instE) sendEmail_(persE, subject, body);

    return {
      ok: true,
      rescheduleCount:    rCount,
      isFinalReschedule:  isFinal,
      msg: isFirst
        ? 'Interview scheduled for ' + slot.date + '. Student notified.'
        : 'Rescheduled (' + rCount + '/' + MAX_RESCHEDULES + ').'
          + (isFinal ? ' FINAL RESCHEDULE -- no further rescheduling allowed.' : '')
    };
  } catch(e) { return { ok: false, msg: e.message }; }
}

// ?? ENTER OUTCOME (post-interview) ????????????????????????????
function enterOutcome(token, appId, outcome, notes) {
  try {
    var startupId = resolveSession_(token, 'startup');
    if (!startupId) return { ok: false, msg: 'Session expired. Please log in again.' };
    var row = findApp_(appId);
    if (!row) return { ok: false, msg: 'Application not found.' };
    if (String(row.data[row.col['Startup_ID']] || '') !== startupId)
      return { ok: false, msg: 'Not authorised.' };

    var status = String(row.data[row.col['Status']] || '');
    var allowedStatuses = [
      'Interview Scheduled',
      'Interview Held -- Outcome Pending'
    ];
    if (allowedStatuses.indexOf(status) < 0)
      return { ok: false, msg: 'Cannot enter outcome for current status: ' + status };

    var instE  = String(row.data[row.col['Institute_Email']] || '');
    var persE  = String(row.data[row.col['Personal_Email']]  || '');
    var sName  = String(row.data[row.col['Student_Name']]    || '');
    var stName = String(row.data[row.col['Startup_Name']]    || '');

    // Always record that interview was held
    updateAppFields_(row, {
      Interview_Held_At:   now_(),
      Outcome_Entered_At:  now_(),
      Notes:               notes || '',
      Last_Updated:        now_()
    });

    if (outcome === 'Selected') {
      var otp      = String(Math.floor(100000 + Math.random() * 900000));
      var salt     = tok_().slice(0, 32);
      var otpHash  = hash_(otp, salt);
      var expiry   = String(Date.now() + OTP_MINUTES * 60000);
      var verifyUrl= execUrl_() + '?page=OTPVerify&appId=' + appId;

      updateAppFields_(row, {
        Status:       'Offer Pending OTP',
        OTP_Hash:     otpHash,
        OTP_Salt:     salt,
        OTP_Expiry:   expiry,
        OTP_Verified: 'No',
        Offer_Sent_At: now_()
      });

      // OTP to institute email ONLY -- security
      sendEmail_(instE,
        'Action required: Confirm your internship offer -- OTP inside | KLE-CTIE',
        buildOTPHtml_(sName, stName, otp, verifyUrl, OTP_MINUTES));
      // Personal email: notification only, no OTP
      if (persE !== instE)
        sendEmail_(persE,
          'You have been selected! Check your institute email | KLE-CTIE',
          buildSelectionNotifyHtml_(sName, instE));

      return { ok: true, outcome: 'Selected',
        msg: 'Offer sent. OTP dispatched to ' + instE + '. Valid ' + OTP_MINUTES + ' minutes.' };

    } else if (outcome === 'Not Selected') {
      updateAppFields_(row, { Status: 'Not Selected' });
      var body = buildNotSelectedHtml_(sName, stName, notes);
      sendEmail_(instE, 'Application update -- ' + stName, body);
      if (persE !== instE) sendEmail_(persE, 'Application update -- ' + stName, body);
      return { ok: true, outcome: 'Not Selected', msg: 'Candidate notified.' };

    } else if (outcome === 'Reschedule') {
      var rCount = parseInt(row.data[row.col['Reschedule_Count']] || '0');
      if (rCount >= MAX_RESCHEDULES) {
        updateAppFields_(row, {
          Status: 'Closed -- Reschedule Limit',
          Notes:  'Closed: reschedule limit reached at outcome entry on ' + today_()
        });
        var b = buildRescheduleLimitHtml_(sName, stName, MAX_RESCHEDULES);
        sendEmail_(instE, 'Application closed', b);
        if (persE !== instE) sendEmail_(persE, 'Application closed', b);
        return { ok: false,
          msg: 'Reschedule limit (' + MAX_RESCHEDULES + ') already reached. Application closed.' };
      }
      rCount++;
      var trackUrl = execUrl_() + '?page=Track&appId=' + appId;
      updateAppFields_(row, {
        Status:           'Shortlisted',   // back to shortlisted so startup can schedule again
        Reschedule_Count: String(rCount)
      });
      var rb = buildRescheduleHtml_(sName, stName, rCount, MAX_RESCHEDULES, trackUrl);
      sendEmail_(instE, 'Interview to be rescheduled -- ' + stName, rb);
      if (persE !== instE) sendEmail_(persE, 'Interview to be rescheduled -- ' + stName, rb);
      return {
        ok: true, outcome: 'Reschedule',
        rescheduleCount: rCount,
        isFinal: rCount === MAX_RESCHEDULES,
        msg: 'Marked for reschedule (' + rCount + '/' + MAX_RESCHEDULES + ').'
          + (rCount === MAX_RESCHEDULES ? ' WARNING: This is the final allowed reschedule.' : '')
      };
    }

    return { ok: false, msg: 'Unknown outcome: ' + outcome };
  } catch(e) { return { ok: false, msg: e.message }; }
}

