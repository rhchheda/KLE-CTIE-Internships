// ?? POST INTERNSHIP ???????????????????????????????????????????
function postInternship(token, data) {
  try {
    var startupId = resolveSession_(token, 'startup');
    if (!startupId) return { ok: false, msg: 'Session expired. Please log in again.' };
    // Verify startup exists and is active
    var stupRow = getStartupRow_(startupId);
    if (!stupRow) return { ok: false, msg: 'Startup not found or not active.' };

    // Validate required fields
    var required = ['roleTitle', 'department', 'skills', 'description',
                    'durationWeeks', 'positions'];
    for (var r = 0; r < required.length; r++) {
      if (!data[required[r]] || !String(data[required[r]]).trim())
        return { ok: false, msg: 'Required field missing: ' + required[r] };
    }
    if (String(data.description || '').trim().length < 50)
      return { ok: false, msg: 'Description must be at least 50 characters.' };

    var sheet    = sh_('INTERNSHIPS');
    var count    = Math.max(sheet.getLastRow(), 1);
    var intId    = 'INT-' + new Date().getFullYear() + '-' + ('000' + count).slice(-3);
    var stipend  = parseFloat(data.stipend || 0);
    var isPaid   = stipend > 0 ? 'Stipend-Based' : 'Academic Internship';

    sheet.appendRow([
      intId,
      startupId,
      stupRow.name,
      data.roleTitle.trim(),
      data.department,
      data.discipline          || 'Any',
      data.qualification       || 'Any',
      data.skills.trim(),
      (data.skillsPreferred    || '').trim(),
      String(data.minCGPA      || '0'),
      data.description.trim(),
      parseInt(data.durationWeeks || 4),
      stipend,
      isPaid,
      parseInt(data.positions  || 1),
      0,                               // Positions_Filled
      data.applicationOpenDate || today_(),
      data.applicationDeadline || '',  // Application_Deadline
      data.internshipStartDate || '',  // Internship_Start_Date
      data.internshipEndDate   || '',  // Internship_End_Date
      data.workMode            || 'On-site',
      data.city                || 'Hubballi',
      data.institutePreference || 'Any',
      data.minYear             || 'Any',
      'Open',
      now_(),
      '',                              // Closed_At
      0,                               // Total_Applications
      0                                // Views
    ]);

    // Increment startup post count
    incrementStartupStat_(startupId, 'Total_Posted');
    SpreadsheetApp.flush();

    // Notify CTIE admin
    sendEmail_(ADMIN_EMAIL,
      '[CTIE Portal] New role posted: ' + data.roleTitle + ' at ' + stupRow.name,
      '<p>A new internship role has been posted.</p>'
      + '<table style="font-size:13px;border-collapse:collapse">'
      + tr_('Internship ID', intId)
      + tr_('Startup',       stupRow.name + ' (' + startupId + ')')
      + tr_('Role',          data.roleTitle)
      + tr_('Department',    data.department)
      + tr_('Discipline',    data.discipline || 'Any')
      + tr_('Positions',     data.positions)
      + tr_('Duration',      data.durationWeeks + ' weeks')
      + tr_('Stipend',       stipend > 0 ? 'Rs.' + stipend + '/month' : 'Academic Internship')
      + tr_('Mode',          data.workMode || 'On-site')
      + '</table>'
    );

    Logger.log('Internship posted: ' + intId + ' by ' + startupId);
    return { ok: true, id: intId, msg: 'Role posted successfully. ID: ' + intId };
  } catch(e) {
    Logger.log('postInternship error: ' + e.message);
    return { ok: false, msg: e.message };
  }
}

// ?? GET OPEN INTERNSHIPS -- public ????????????????????????????
function getOpenInternships(filters) {
  try {
    var sheet = sh_('INTERNSHIPS');
    if (!sheet || sheet.getLastRow() < 2) return { ok: true, internships: [] };
    var data  = sheet.getDataRange().getValues();
    var heads = data[0];
    var col   = cols_(heads);
    var f     = filters || {};

    var list = data.slice(1).filter(function(row) {
      if (String(row[col['Status']] || '') !== 'Open') return false;
      if (f.sector && String(row[col['Department']] || '') !== f.sector) return false;
      if (f.mode   && String(row[col['Work_Mode']]  || '') !== f.mode)   return false;
      if (f.discipline && String(row[col['Discipline']] || '').indexOf(f.discipline) < 0
          && f.discipline !== 'Any') return false;
      if (f.paid === 'yes' && parseFloat(row[col['Stipend_INR']] || 0) <= 0) return false;
      if (f.paid === 'no'  && parseFloat(row[col['Stipend_INR']] || 0) >  0) return false;
      return true;
    }).map(function(row) {
      var obj = {};
      heads.forEach(function(h, i) { obj[h] = row[i]; });
      return obj;
    });

    var logos = startupLogoMap_();
    list.forEach(function(item) {
      item.Logo_URL = logos[String(item.Startup_ID || '')] || '';
    });

    return jsonSafe_({ ok: true, internships: list, total: list.length });
  } catch(e) {
    Logger.log('getOpenInternships error: ' + e.message);
    return { ok: false, msg: e.message, internships: [] };
  }
}

// Startup_ID -> Logo_URL, for enriching public internship listings with the
// posting startup's brand image without exposing any other startup fields.
function startupLogoMap_() {
  var map = {};
  try {
    var sheet = sh_('STARTUPS');
    if (!sheet || sheet.getLastRow() < 2) return map;
    var data = sheet.getDataRange().getValues();
    var col  = cols_(data[0]);
    for (var i = 1; i < data.length; i++) {
      map[String(data[i][col['Startup_ID']] || '')] = String(data[i][col['Logo_URL']] || '');
    }
  } catch(e) { Logger.log('startupLogoMap_ error: ' + e.message); }
  return map;
}

// ── HOME PAGE STATS -- public ──────────────────────────────────
function getHomeStats() {
  try {
    var sheet = sh_('INTERNSHIPS');
    if (!sheet || sheet.getLastRow() < 2)
      return { ok: true, openPositions: 0, startupsHiring: 0, sectors: 0, stipendRoles: 0 };

    var data  = sheet.getDataRange().getValues();
    var heads = data[0];
    var col   = cols_(heads);
    var open  = data.slice(1).filter(function(row) {
      return String(row[col['Status']] || '') === 'Open';
    });

    var openPositions = open.reduce(function(sum, row) {
      var avail  = parseInt(row[col['Positions_Available']] || 0);
      var filled = parseInt(row[col['Positions_Filled']]    || 0);
      return sum + Math.max(avail - filled, 0);
    }, 0);
    var startups = {};
    var sectors  = {};
    var stipendRoles = 0;
    open.forEach(function(row) {
      startups[String(row[col['Startup_ID']]  || '')] = true;
      sectors[String(row[col['Department']]   || '')] = true;
      if (parseFloat(row[col['Stipend_INR']] || 0) > 0) stipendRoles++;
    });

    return {
      ok: true,
      openPositions:  openPositions,
      startupsHiring: Object.keys(startups).length,
      sectors:        Object.keys(sectors).length,
      stipendRoles:   stipendRoles
    };
  } catch(e) {
    Logger.log('getHomeStats error: ' + e.message);
    return { ok: false, msg: e.message, openPositions: 0, startupsHiring: 0, sectors: 0, stipendRoles: 0 };
  }
}

// Looks up a student's most recent application by institute email, to
// auto-fill a fresh application form -- public, no session token, since
// this runs before any account exists for a student. Deliberately returns
// only academic-profile fields (name, institute, course, year), never
// mobile or CGPA, since an institute email is guessable (roll-number
// based addresses) and this endpoint has no way to verify the caller is
// the same person who applied before.
function getApplicantProfile(instituteEmail) {
  try {
    var email = String(instituteEmail || '').trim().toLowerCase();
    if (!email || email.indexOf('@') < 0) return { ok: true, found: false };

    var sheet = sh_('APPLICATIONS');
    if (!sheet || sheet.getLastRow() < 2) return { ok: true, found: false };
    var data = sheet.getDataRange().getValues();
    var col  = cols_(data[0]);

    // Rows are appended chronologically, so the last match is the most recent.
    var match = null;
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][col['Institute_Email']] || '').toLowerCase() === email) match = data[i];
    }
    if (!match) return { ok: true, found: false };

    return {
      ok: true, found: true,
      name:          String(match[col['Student_Name']]   || ''),
      instituteName: String(match[col['Institute_Name']] || ''),
      course:        String(match[col['Course']]          || ''),
      year:          String(match[col['Year']]            || '')
    };
  } catch(e) { return { ok: true, found: false }; }
}

// Institutes + departments for the apply form's dropdowns and admin Reports
// filters -- public, no token (needed before any account exists). Only
// names are returned, never HoD_Name/HoD_Email (kept out of any
// unauthenticated response). Cached briefly so a burst of page loads
// doesn't hit the Sheet every time, while new rows still show up within
// about a minute of being hand-added to the DEPARTMENTS tab.
function getInstituteDepartments() {
  try {
    var cache  = CacheService.getScriptCache();
    var cached = cache.get('dept_list');
    if (cached) return JSON.parse(cached);

    var result = { ok: true, institutes: [] };
    var sheet  = sh_('DEPARTMENTS');
    if (sheet && sheet.getLastRow() > 1) {
      var data  = sheet.getDataRange().getValues();
      var col   = cols_(data[0]);
      var map   = {};
      var order = [];
      for (var i = 1; i < data.length; i++) {
        var row = data[i];
        if (String(row[col['Active']] || '').toUpperCase() !== 'TRUE') continue;
        var inst = String(row[col['Institute_Name']]  || '').trim();
        var dept = String(row[col['Department_Name']] || '').trim();
        if (!inst || !dept) continue;
        if (!map[inst]) { map[inst] = []; order.push(inst); }
        if (map[inst].indexOf(dept) < 0) map[inst].push(dept);
      }
      result.institutes = order.map(function(inst) { return { name: inst, departments: map[inst] }; });
    }

    cache.put('dept_list', JSON.stringify(result), 60);
    return result;
  } catch(e) {
    // Fail open -- the apply form's "Other" free-text fallback still works
    // even if this list can't be read, so a broken sheet never blocks applying.
    return { ok: true, institutes: [] };
  }
}

// ?? SUBMIT APPLICATION -- public ??????????????????????????????
function submitApplication(data) {
  try {
    // Validate institute email
    var instEmail = String(data.instituteEmail || '').trim().toLowerCase();
    if (!instEmail || instEmail.indexOf('@') < 0)
      return { ok: false, msg: 'Valid institute email required.' };
    if (isPersonalEmail_(instEmail))
      return { ok: false, msg: 'Please use your institution-provided email, not a personal email (Gmail, Yahoo, etc.).' };

    // Personal email required
    var persEmail = String(data.personalEmail || '').trim().toLowerCase();
    if (!persEmail || persEmail.indexOf('@') < 0)
      return { ok: false, msg: 'Personal email is required for post-graduation contact.' };

    // Validate required fields
    var required = ['studentName','mobile','instituteName','course',
                    'yearOfStudy','skills','whyInterested','internshipId'];
    for (var r = 0; r < required.length; r++) {
      if (!data[required[r]] || !String(data[required[r]]).trim())
        return { ok: false, msg: 'Required field missing: ' + required[r] };
    }

    if (!isValidName_(data.studentName))
      return { ok: false, msg: 'Enter your name using letters only (no numbers or symbols).' };
    if (!isValidMobile_(data.mobile))
      return { ok: false, msg: 'Enter a valid 10-digit Indian mobile number.' };
    var studentNameClean = toProperCase_(data.studentName);

    var wordCount = String(data.whyInterested || '').trim()
      .split(/\s+/).filter(function(w){ return w.length > 0; }).length;
    if (wordCount < 20)
      return { ok: false, msg: 'Why interested must be at least 20 words (' + wordCount + ' written).' };

    var sheet = sh_('APPLICATIONS');
    if (!sheet) return { ok: false, msg: 'System not initialised. Run setupSheets().' };

    // Duplicate check -- same role, and the same student identified by ANY
    // of institute email, personal email, or mobile number. Checking only
    // institute email would let someone reapply by typing a slightly
    // different (or a second, legitimate) institute address; mobile and
    // personal email are much harder to vary between attempts.
    var existing     = sheet.getDataRange().getValues();
    var heads        = existing[0];
    var col          = cols_(heads);
    var mobileNorm   = normalizeMobile_(data.mobile);
    for (var i = 1; i < existing.length; i++) {
      if (String(existing[i][col['Internship_ID']] || '') !== data.internshipId) continue;
      var sameInstEmail = String(existing[i][col['Institute_Email']] || '').toLowerCase() === instEmail;
      var samePersEmail = String(existing[i][col['Personal_Email']]  || '').toLowerCase() === persEmail;
      var sameMobile    = normalizeMobile_(existing[i][col['Mobile']]) === mobileNorm;
      if (sameInstEmail || samePersEmail || sameMobile)
        return { ok: false, msg: 'You have already applied for this role.' };
    }

    // Fetch internship details
    var intSheet = sh_('INTERNSHIPS');
    var intData  = intSheet.getDataRange().getValues();
    var intHeads = intData[0];
    var intCol   = cols_(intHeads);
    var startupId = '', startupName = '', roleTitle = '';
    for (var j = 1; j < intData.length; j++) {
      if (String(intData[j][intCol['Internship_ID']] || '') === data.internshipId) {
        startupId   = String(intData[j][intCol['Startup_ID']]   || '');
        startupName = String(intData[j][intCol['Startup_Name']] || '');
        roleTitle   = String(intData[j][intCol['Role_Title']]   || '');
        // Increment application counter
        var appCount = parseInt(intData[j][intCol['Total_Applications']] || 0);
        intSheet.getRange(j + 1, intCol['Total_Applications'] + 1)
          .setValue(appCount + 1);
        break;
      }
    }
    if (!startupId) return { ok: false, msg: 'Internship not found.' };

    // Generate unique App ID
    var appCount = Math.max(sheet.getLastRow(), 1);
    var appId = 'APP-' + new Date().getFullYear() + '-'
               + ('0000' + appCount).slice(-4) + '-'
               + tok_().slice(0, 4).toUpperCase();

    // Append application row (column order matches SCHEMA.APPLICATIONS)
    sheet.appendRow([
      appId,                          // App_ID
      data.internshipId,              // Internship_ID
      startupId,                      // Startup_ID
      startupName,                    // Startup_Name
      studentNameClean,                // Student_Name
      instEmail,                      // Institute_Email
      persEmail,                      // Personal_Email
      data.mobile.trim(),             // Mobile
      data.instituteName.trim(),      // Institute_Name
      data.course.trim(),             // Course
      data.yearOfStudy,               // Year
      data.cgpa || '',                // CGPA
      data.skills.trim(),             // Skills
      data.whyInterested.trim(),      // Why_Interested
      data.resumeUrl || '',           // Resume_URL
      'Applied',                      // Status
      now_(),                         // Applied_At
      '',                             // Shortlisted_At
      '0',                            // Reschedule_Count
      '', '', '', '',                 // Interview_1 slot
      '', '', '', '',                 // Interview_2 slot
      '', '', '', '',                 // Interview_3 slot
      '1',                            // Active_Interview_Slot
      '', '',                         // Interview_Held_At, Outcome_Entered_At
      '', '', '', 'No',               // OTP fields
      '', '', '',                     // Selected_At, Offer_Sent_At, Confirmed_At
      '', '', '',                     // Intern_Start, Intern_End, Completion_Status
      '', '',                         // Startup_Rating, Startup_Feedback
      '', now_(),                     // Notes, Last_Updated
      data.resumeFileId || '',        // Resume_File_ID
      data.resumeFileId ? now_() : '' // Resume_Updated_At
    ]);
    SpreadsheetApp.flush();

    // Resume was uploaded under a temp name before the App_ID existed --
    // rename it now for easy identification in Drive.
    if (data.resumeFileId)
      renameResumeFile_(data.resumeFileId, appId, studentNameClean, data.resumeMimeType || '');

    // Confirmation emails -- both addresses
    var trackUrl = execUrl_() + '?page=Track&appId=' + appId;
    var subject  = 'Application received -- ' + appId + ' | KLE-CTIE';
    var body     = buildAppConfirmHtml_(studentNameClean, appId, roleTitle, startupName, trackUrl);
    sendEmail_(instEmail, subject, body);
    if (persEmail !== instEmail) sendEmail_(persEmail, subject, body);

    Logger.log('Application submitted: ' + appId + ' for ' + data.internshipId);
    return { ok: true, appId: appId,
      msg: 'Application submitted. Your ID is ' + appId + '. Confirmation sent to both emails.' };
  } catch(e) {
    Logger.log('submitApplication error: ' + e.message);
    return { ok: false, msg: e.message };
  }
}

