function verifyOTP(appId, otp) {
  try {
    var row = findApp_(appId);
    if (!row) return { ok: false, msg: 'Application not found.' };

    var status   = String(row.data[row.col['Status']]        || '');
    var stored   = String(row.data[row.col['OTP_Hash']]      || '');
    var salt     = String(row.data[row.col['OTP_Salt']]      || '');
    var expiry   = parseInt(row.data[row.col['OTP_Expiry']]  || '0');
    var verified = String(row.data[row.col['OTP_Verified']]  || 'No');

    if (status !== 'Offer Pending OTP')
      return { ok: false, msg: 'No pending offer. Current status: ' + status };
    if (verified === 'Yes')
      return { ok: false, msg: 'OTP already verified. Your acceptance is confirmed.' };
    if (Date.now() > expiry)
      return { ok: false, msg: 'OTP has expired. Ask the startup to re-enter the selection.' };

    // Rate limiting -- track attempts in Notes
    var notes    = String(row.data[row.col['Notes']] || '');
    var attempts = parseInt((notes.match(/OTP_ATTEMPTS:(\d+)/) || [0, 0])[1]);
    if (attempts >= OTP_MAX_ATTEMPTS)
      return { ok: false, msg: 'Too many incorrect attempts (' + OTP_MAX_ATTEMPTS + '). Ask the startup to re-select you.' };

    if (hash_(otp.trim(), salt) !== stored) {
      attempts++;
      var updatedNotes = notes.replace(/OTP_ATTEMPTS:\d+/, '') + ' OTP_ATTEMPTS:' + attempts;
      updateAppFields_(row, { Notes: updatedNotes.trim() });
      var remaining = OTP_MAX_ATTEMPTS - attempts;
      return { ok: false,
        msg: 'Incorrect OTP. ' + remaining + ' attempt' + (remaining === 1 ? '' : 's') + ' remaining.' };
    }

    // OTP correct -- confirm selection
    updateAppFields_(row, {
      OTP_Verified: 'Yes',
      Status:       'Selected',
      Confirmed_At: now_(),
      Notes:        notes.replace(/OTP_ATTEMPTS:\d+/, '').trim(),
      Last_Updated: now_()
    });

    // Update positions filled on the internship
    var intId  = String(row.data[row.col['Internship_ID']] || '');
    var intSh  = sh_('INTERNSHIPS');
    var intData= intSh.getDataRange().getValues();
    var intCol = cols_(intData[0]);
    for (var j = 1; j < intData.length; j++) {
      if (String(intData[j][intCol['Internship_ID']] || '') !== intId) continue;
      var filled = parseInt(intData[j][intCol['Positions_Filled']] || 0) + 1;
      var avail  = parseInt(intData[j][intCol['Positions_Available']] || 1);
      intSh.getRange(j + 1, intCol['Positions_Filled'] + 1).setValue(filled);
      if (filled >= avail)
        intSh.getRange(j + 1, intCol['Status'] + 1).setValue('Full');
      break;
    }

    var sName  = String(row.data[row.col['Student_Name']]    || '');
    var stName = String(row.data[row.col['Startup_Name']]    || '');
    var instE  = String(row.data[row.col['Institute_Email']] || '');
    var persE  = String(row.data[row.col['Personal_Email']]  || '');
    var welcomeBody = buildWelcomeHtml_(sName, stName);
    sendEmail_(instE, 'Internship confirmed! Welcome aboard | KLE-CTIE', welcomeBody);
    if (persE !== instE)
      sendEmail_(persE, 'Internship confirmed! Welcome aboard | KLE-CTIE', welcomeBody);
    sendEmail_(ADMIN_EMAIL,
      '[CTIE Portal] Intern confirmed: ' + appId,
      sName + ' has confirmed internship with ' + stName + ' (' + appId + ')');

    // Sync KPI to TBI main sheet if configured
    syncInternKPI_();

    Logger.log('OTP verified, internship confirmed: ' + appId);
    return { ok: true, studentName: sName, startupName: stName,
      msg: 'Internship confirmed! Welcome email sent to both your addresses.' };
  } catch(e) { return { ok: false, msg: e.message }; }
}

// ?? RESEND OTP ????????????????????????????????????????????????
function resendOTP(appId) {
  try {
    var row = findApp_(appId);
    if (!row) return { ok: false, msg: 'Application not found.' };

    var status = String(row.data[row.col['Status']] || '');
    if (status !== 'Offer Pending OTP')
      return { ok: false, msg: 'No pending offer. Status: ' + status };

    var otp     = String(Math.floor(100000 + Math.random() * 900000));
    var salt    = tok_().slice(0, 32);
    var expiry  = String(Date.now() + OTP_MINUTES * 60000);
    var notes   = String(row.data[row.col['Notes']] || '');

    updateAppFields_(row, {
      OTP_Hash:     hash_(otp, salt),
      OTP_Salt:     salt,
      OTP_Expiry:   expiry,
      OTP_Verified: 'No',
      Notes:        notes.replace(/OTP_ATTEMPTS:\d+/, '').trim()  // reset attempts
    });

    var instE   = String(row.data[row.col['Institute_Email']] || '');
    var sName   = String(row.data[row.col['Student_Name']]    || '');
    var stName  = String(row.data[row.col['Startup_Name']]    || '');
    var verifyUrl = execUrl_() + '?page=OTPVerify&appId=' + appId;
    sendEmail_(instE, 'New OTP: Confirm your internship -- KLE-CTIE',
      buildOTPHtml_(sName, stName, otp, verifyUrl, OTP_MINUTES));

    return { ok: true, msg: 'New OTP sent to ' + instE + '. Valid ' + OTP_MINUTES + ' minutes.' };
  } catch(e) { return { ok: false, msg: e.message }; }
}

