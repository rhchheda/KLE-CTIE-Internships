// ── CORE HELPERS ──────────────────────────────────────────────
function sheetId_() {
  var id = PropertiesService.getScriptProperties().getProperty('SHEET_ID');
  if (!id) throw new Error('SHEET_ID not set. Go to Project Settings > Script Properties and add SHEET_ID.');
  return id;
}
function SS_()  { return SpreadsheetApp.openById(sheetId_()); }
function sh_(t) { return SS_().getSheetByName(t); }

function now_() {
  return Utilities.formatDate(new Date(), TZ, 'dd-MMM-yyyy HH:mm:ss');
}
function today_() {
  return Utilities.formatDate(new Date(), TZ, 'dd-MMM-yyyy');
}
function tok_() {
  return Utilities.getUuid().replace(/-/g, '');
}
// Sheets silently converts a recognisable date-only or time-only string
// (e.g. "2026-07-17" from <input type="date">, "10:00" from <input
// type="time">) into a real Date object on write. Left alone,
// JSON.stringify turns that into a full UTC ISO timestamp -- wrong
// timezone, and useless for re-populating a date/time input or for
// display. Sheets' own internal marker for a time-only value is the epoch
// date (30 Dec 1899), which is what tells the two cases apart here.
function formatSheetDate_(d) {
  return d.getFullYear() === 1899
    ? Utilities.formatDate(d, TZ, 'HH:mm')
    : Utilities.formatDate(d, TZ, 'yyyy-MM-dd');
}
// Same idea as formatSheetDate_(), for the handful of places that read a
// cell directly (server-side logic, not a client-facing jsonSafe_ response)
// and need a plain string regardless of whether Sheets auto-converted it.
function cellStr_(v) {
  return (Object.prototype.toString.call(v) === '[object Date]') ? formatSheetDate_(v) : String(v || '');
}
// Force a clean plain-JSON round-trip before crossing the google.script.run
// bridge. Sheet cells that look like dates/times can come back from
// getValues() as real Date objects (or other rich types) instead of plain
// strings, which have been observed to serialize as raw Java toString()
// output (e.g. "[Ljava.lang.Object;@hash") instead of JSON. This guarantees
// plain, JSON-safe values every time, formatting any Date cell via
// formatSheetDate_() instead of the default UTC-timestamp toJSON().
function jsonSafe_(obj) {
  return JSON.parse(JSON.stringify(obj, function(key, value) {
    return (this[key] instanceof Date) ? formatSheetDate_(this[key]) : value;
  }));
}
function hash_(value, salt) {
  var bytes = Utilities.computeDigest(
    Utilities.DigestAlgorithm.SHA_256,
    value + salt,
    Utilities.Charset.UTF_8
  );
  return bytes.map(function(b) {
    return ('0' + (b < 0 ? b + 256 : b).toString(16)).slice(-2);
  }).join('');
}
function cols_(headers) {
  var map = {};
  headers.forEach(function(h, i) { if (h) map[h] = i; });
  return map;
}
function execUrl_() {
  // Prefer a manually set PORTAL_URL property (most reliable)
  var manual = PropertiesService.getScriptProperties().getProperty('PORTAL_URL');
  if (manual && manual.indexOf('https://') === 0) return manual;
  // Fall back to ScriptApp -- ensure we get /exec not /dev
  try {
    var url = ScriptApp.getService().getUrl();
    return url.replace('/dev', '/exec');
  } catch(e) {
    return '';
  }
}
// A plain Google Drive "share" link (.../file/d/ID/view?usp=sharing) is an
// HTML viewer page, not raw image bytes -- an <img src> pointed at one just
// shows a broken image, even when sharing is set to "Anyone with the link".
// Rewrites any Drive URL (share link, uc?id= link, or a bare file ID) into
// a format that actually renders as an image; leaves non-Drive URLs alone.
function driveDirectImageUrl_(input) {
  var s = String(input || '').trim();
  if (!s || s.indexOf('drive.google.com') < 0) return s;
  var id = '';
  var m = s.match(/\/file\/d\/([a-zA-Z0-9_-]+)/) || s.match(/[?&]id=([a-zA-Z0-9_-]+)/);
  if (m) id = m[1];
  if (!id) return s; // unrecognised Drive URL shape -- leave as typed
  return 'https://lh3.googleusercontent.com/d/' + id;
}
function isPersonalEmail_(email) {
  var domain = String(email||'').toLowerCase().split('@')[1] || '';
  return BLOCKED_EMAIL_DOMAINS.indexOf(domain) >= 0;
}
// Normalises free-typed names ("KAVYA DESAI", "kavya desai") to "Kavya Desai"
// so display is consistent regardless of how a student/startup typed it.
// Deliberately NOT used for institute names -- those legitimately contain
// acronyms (KLE, NIT, BVB, VTU, SDM) that blind title-casing would mangle.
function toProperCase_(str) {
  str = String(str || '').trim().replace(/\s+/g, ' ');
  if (!str) return '';
  return str.toLowerCase().replace(/[a-z]+/g, function(word) {
    return word.charAt(0).toUpperCase() + word.slice(1);
  });
}
// A person/company name: letters, spaces, and the handful of punctuation
// marks real names actually use (apostrophe, hyphen, period for initials).
// Rejects pure numbers, symbol strings, and single-character noise.
function isValidName_(str) {
  return /^[A-Za-z][A-Za-z.'\-]*(?: [A-Za-z.'\-]+)*$/.test(String(str || '').trim())
    && String(str).trim().length >= 2 && String(str).trim().length <= 80;
}
// Indian mobile number: 10 digits, optionally with a +91/91/0 prefix.
function isValidMobile_(str) {
  var digits = String(str || '').replace(/[\s\-()]/g, '');
  return /^(\+?91|0)?[6-9]\d{9}$/.test(digits);
}
// Comparison key for a mobile number, stripped of formatting/country-code
// prefix -- so "+91 98765 43210", "09876543210", and "9876543210" all match.
function normalizeMobile_(str) {
  return String(str || '').replace(/\D/g, '').slice(-10);
}
// Reads a tunable value from the CONFIG sheet (admin-editable without a code
// change). Falls back to the given default if the sheet/key isn't found.
function getConfigValue_(key, fallback) {
  try {
    var sheet = sh_('CONFIG');
    if (!sheet || sheet.getLastRow() < 2) return fallback;
    var data = sheet.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][0] || '') === key) {
        var val = parseFloat(data[i][1]);
        return isNaN(val) ? fallback : val;
      }
    }
    return fallback;
  } catch(e) { return fallback; }
}
// Last-modified timestamp of the backing Sheet, for the site footer.
// Cached in CacheService for 60s so every page load doesn't cost a Drive API call.
function getSheetLastUpdated_() {
  var CACHE_KEY = 'sheet_last_updated';
  try {
    var cache  = CacheService.getScriptCache();
    var cached = cache.get(CACHE_KEY);
    if (cached) return cached;

    var d   = DriveApp.getFileById(sheetId_()).getLastUpdated();
    var out = Utilities.formatDate(d, TZ, 'dd-MMM-yyyy, hh:mm a');
    cache.put(CACHE_KEY, out, 60);
    return out;
  } catch(e) {
    return '';
  }
}

// ── SESSIONS ──────────────────────────────────────────────────
// GAS web apps expose every top-level function to any caller via
// google.script.run, regardless of which HTML page references it --
// there is no built-in per-function access control. These helpers are
// the actual gate: privileged functions must resolve an identity from
// a signed-nothing-but-cache-backed token, never trust a client-supplied
// startupId/role directly.
var SESSION_TTL_SEC = 6 * 60 * 60; // 6h sliding session (CacheService max)

function createSession_(role, id) {
  var token = tok_();
  CacheService.getScriptCache().put(
    'sess_' + token, JSON.stringify({ role: role, id: id }), SESSION_TTL_SEC);
  return token;
}
// Returns the session's id if token is valid and matches expectedRole, else null.
// Extends the session (sliding expiry) on every successful resolve.
function resolveSession_(token, expectedRole) {
  if (!token) return null;
  var cache = CacheService.getScriptCache();
  var raw   = cache.get('sess_' + token);
  if (!raw) return null;
  var sess;
  try { sess = JSON.parse(raw); } catch(e) { return null; }
  if (sess.role !== expectedRole) return null;
  cache.put('sess_' + token, raw, SESSION_TTL_SEC); // slide expiry
  return sess.id;
}
function destroySession_(token) {
  if (!token) return;
  CacheService.getScriptCache().remove('sess_' + token);
}
function logout(token) {
  destroySession_(token);
  return { ok: true };
}

// ── LOGIN LOCKOUT (brute-force protection) ────────────────────
// Neither adminLogin nor startupLogin had any limit on wrong-PIN guesses --
// a 4-digit startup PIN is only 10,000 combinations, trivially guessable
// without this. Tracked in CacheService (ephemeral, self-expiring) keyed
// per-identity, so one locked-out startup doesn't affect others.
var LOGIN_MAX_ATTEMPTS    = 5;
var LOGIN_LOCKOUT_MINUTES = 15;

function checkLoginLockout_(identityKey) {
  var raw = CacheService.getScriptCache().get('lockout_' + identityKey);
  if (!raw) return null;
  var data = JSON.parse(raw);
  if (data.count >= LOGIN_MAX_ATTEMPTS)
    return 'Too many incorrect attempts. Try again in ' + LOGIN_LOCKOUT_MINUTES + ' minutes.';
  return null;
}
// Returns attempts remaining before lockout (0 or negative once locked).
function recordLoginFailure_(identityKey) {
  var cache = CacheService.getScriptCache();
  var raw   = cache.get('lockout_' + identityKey);
  var data  = raw ? JSON.parse(raw) : { count: 0 };
  data.count++;
  cache.put('lockout_' + identityKey, JSON.stringify(data), LOGIN_LOCKOUT_MINUTES * 60);
  return LOGIN_MAX_ATTEMPTS - data.count;
}
function clearLoginLockout_(identityKey) {
  CacheService.getScriptCache().remove('lockout_' + identityKey);
}

// ── ADMIN AUTH ────────────────────────────────────────────────
// Bootstrap pattern (matches startupLogin below): the admin PIN is never
// hardcoded or pre-seeded. The first successful call sets it (hashed) in
// Script Properties; every call after that must match the stored hash.
// Caveat: whoever submits a PIN first "claims" the admin account -- log
// in immediately after deploying, before sharing the portal URL.
function adminLogin(pin) {
  try {
    var lockMsg = checkLoginLockout_('admin');
    if (lockMsg) return { ok: false, msg: lockMsg };

    if (!pin || String(pin).length < 6 || !/^\d+$/.test(pin))
      return { ok: false, msg: 'Admin PIN must be at least 6 digits.' };

    var props      = PropertiesService.getScriptProperties();
    var storedHash = props.getProperty('ADMIN_PIN_HASH');
    var storedSalt = props.getProperty('ADMIN_PIN_SALT');

    if (!storedHash) {
      var salt = tok_().slice(0, 32);
      props.setProperty('ADMIN_PIN_SALT', salt);
      props.setProperty('ADMIN_PIN_HASH', hash_(pin, salt));
      clearLoginLockout_('admin');
      return { ok: true, token: createSession_('admin', 'ctie-admin'),
        isFirst: true, msg: 'Admin PIN set. Welcome to KLE-CTIE Internship Portal.' };
    }

    if (hash_(pin, storedSalt) !== storedHash) {
      var remaining = recordLoginFailure_('admin');
      return { ok: false, msg: remaining > 0
        ? 'Incorrect PIN. ' + remaining + ' attempt' + (remaining === 1 ? '' : 's') + ' remaining before temporary lockout.'
        : 'Too many incorrect attempts. Locked for ' + LOGIN_LOCKOUT_MINUTES + ' minutes.' };
    }

    clearLoginLockout_('admin');
    return { ok: true, token: createSession_('admin', 'ctie-admin'), msg: 'Welcome back.' };
  } catch(e) {
    return { ok: false, msg: 'Login error: ' + e.message };
  }
}

// ── doGet -- ROUTER ───────────────────────────────────────────
function doGet(e) {
  var params = e && e.parameter ? e.parameter : {};
  var page   = String(params.page || '');
  var props  = PropertiesService.getScriptProperties();

  // Asset handler -- serve logos from Drive as base64 data URIs
  // Usage: ?asset=kle_logo or ?asset=ctie_logo
  if (params.asset) {
    return serveAsset_(params.asset, props);
  }

  // Route map -- public pages (no auth required)
  var publicRoutes = {
    '':               { file: 'InternHome',     data: {} },
    'Home':           { file: 'InternHome',     data: {} },
    'Browse':         { file: 'InternBrowse',   data: {} },
    'Track':          { file: 'InternTrack',    data: { appId: params.appId || '', from: params.from || '' } },
    'OTPVerify':      { file: 'InternOTPVerify',data: { appId: params.appId || '' } },
    'HelpStudent':    { file: 'HelpStudent',    data: {} },
    'HelpStartup':    { file: 'HelpStartup',    data: {} },
    'HelpAdmin':      { file: 'HelpAdmin',      data: {} },
    'Profile':        { file: 'StartupProfile', data: { startupId: params.id || '' } },
  };

  // Startup-facing pages (PIN auth handled client-side via startupLogin())
  var startupRoutes = {
    'StartupPortal':  { file: 'StartupPortal', data: {} },
    'PostRole':       { file: 'PostRole',      data: {} },
  };

  // CTIE admin pages (admin PIN handled client-side)
  var adminRoutes = {
    'Admin':          { file: 'AdminDashboard', data: {} },
    'AdminSettings':  { file: 'AdminSettings',  data: {} },
    'AdminReports':   { file: 'Reports',        data: {} },
  };

  var route = publicRoutes[page] || startupRoutes[page] || adminRoutes[page];
  if (route) return buildPage_(route.file, route.data);

  // Fallback -- unknown page -> home
  Logger.log('Unknown page requested: ' + page);
  return buildPage_('InternHome', {});
}

// ?? PAGE BUILDER ??????????????????????????????????????????????
function buildPage_(fileName, data) {
  var url = execUrl_();
  var tpl;

  // Step 1 -- create template (file must exist in this Apps Script project)
  try {
    tpl = HtmlService.createTemplateFromFile(fileName);
  } catch(fileErr) {
    Logger.log('FILE NOT FOUND in Apps Script: "' + fileName + '" -- ' + fileErr.message);
    return buildErrorPage_(
      fileName,
      'File "' + fileName + '" not found in this Apps Script project. '
      + 'Check that the file exists and is named exactly "' + fileName
      + '" (no .html extension in the name field).'
    );
  }

  // Step 2 -- pre-set ALL known template variables to empty string
  var ALL_VARS = [
    'EXEC_URL', 'KLE_LOGO', 'CTIE_LOGO', 'LAST_UPDATED',
    'appId', 'startupId', 'internshipId',
    'errorMsg', 'page', 'role', 'from'
  ];
  ALL_VARS.forEach(function(k) { tpl[k] = ''; });
  tpl.EXEC_URL      = url;
  tpl.LAST_UPDATED  = getSheetLastUpdated_();

  // Logos ship in source (see KLE_LOGO_B64/CTIE_LOGO_B64 above, sourced from
  // /assets) -- no Google Drive dependency. An admin can still override with
  // a Script Property (kle_logo_url / ctie_logo_url) if they want a different
  // image without touching code.
  var props_ = PropertiesService.getScriptProperties().getProperties();
  tpl.KLE_LOGO  = props_['kle_logo_url']  || KLE_LOGO_B64;
  tpl.CTIE_LOGO = props_['ctie_logo_url'] || CTIE_LOGO_B64;

  // Inject all page URLs as a JSON object for safe JS navigation
  tpl.PAGES_JSON = JSON.stringify({
    Home:          url,
    Browse:        url + '?page=Browse',
    Track:         url + '?page=Track',
    StartupPortal: url + '?page=StartupPortal',
    PostRole:      url + '?page=PostRole',
    Admin:         url + '?page=Admin',
    AdminReports:  url + '?page=AdminReports',
    AdminSettings: url + '?page=AdminSettings',
    HelpStudent:   url + '?page=HelpStudent',
    HelpStartup:   url + '?page=HelpStartup',
    HelpAdmin:     url + '?page=HelpAdmin'
  });

  // Step 3 -- inject page-specific data
  var safeData = data || {};
  Object.keys(safeData).forEach(function(k) {
    tpl[k] = String(safeData[k] !== undefined && safeData[k] !== null
      ? safeData[k] : '');
  });

  // Step 4 -- evaluate template
  try {
    return tpl.evaluate()
      .setTitle(PORTAL_TITLE)
      .addMetaTag('viewport', 'width=device-width,initial-scale=1')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
  } catch(evalErr) {
    Logger.log('TEMPLATE ERROR in "' + fileName + '": ' + evalErr.message);
    return buildErrorPage_(fileName, evalErr.message);
  }
}

// ── DIAGNOSTIC: run from Apps Script editor to check all files ─
function checkAllFiles() {
  var required = [
    'InternHome','InternBrowse','InternTrack','InternOTPVerify',
    'StartupPortal','PostRole','StartupProfile',
    'AdminDashboard','Reports','AdminSettings',
    'HelpStudent','HelpStartup','HelpAdmin'
  ];
  var results = [];
  required.forEach(function(name) {
    try {
      HtmlService.createTemplateFromFile(name);
      results.push('OK: ' + name);
    } catch(e) {
      results.push('MISSING: ' + name + ' -- ' + e.message);
    }
  });
  Logger.log('File Check Results:\n\n' + results.join('\n'));
  return results;
}

