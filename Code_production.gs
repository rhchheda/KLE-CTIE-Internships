  for (var i = 1; i < data.length; i++) {
    if (String(data[i][col['Startup_ID']] || '') === startupId
        && String(data[i][col['Active']]  || '').toUpperCase() === 'TRUE')
      return {
        row:  data[i],
        col:  col,
