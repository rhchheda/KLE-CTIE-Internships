  if (mode === 'In-person') {
    return '<tr><td style="padding:5px 10px 5px 0;color:#888;font-size:12px;'
      + 'vertical-align:top">Venue</td>'
      + '<td style="padding:5px 0;font-size:12px;font-weight:700;color:#1a1a2e">'
      + value + '</td></tr>';
