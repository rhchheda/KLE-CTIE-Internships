// Applications sitting in Applied for too long -- nudge or auto-close
function checkReviewSLA_() {
  var sheet = sh_('APPLICATIONS');
  if (!sheet || sheet.getLastRow() < 2) return;
  var data  = sheet.getDataRange().getValues();
  var heads = data[0];
  var col   = cols_(heads);
  var now   = Date.now();

  data.slice(1).forEach(function(row, i) {
    if (String(row[col['Status']] || '') !== 'Applied') return;
    var appAt = new Date(String(row[col['Applied_At']] || '')).getTime();
    if (!appAt || isNaN(appAt)) return;
    var daysOld  = (now - appAt) / 86400000;
    var startupId= String(row[col['Startup_ID']]  || '');
    var appId    = String(row[col['App_ID']]       || '');
    var sName    = String(row[col['Student_Name']] || '');
    var stName   = String(row[col['Startup_Name']] || '');

    if (Math.floor(daysOld) === REVIEW_SLA_DAYS) {
      notifyStartup_(startupId,
        '[CTIE SLA] ' + REVIEW_SLA_DAYS + '-day review reminder',
        'You have applications pending review for ' + REVIEW_SLA_DAYS
        + ' days. Applications auto-close at day ' + REVIEW_CLOSE_DAYS
        + '. Please log in to review.');
    }
    if (daysOld >= REVIEW_CLOSE_DAYS) {
      sheet.getRange(i + 2, col['Status'] + 1).setValue('Closed -- No Response');
      sheet.getRange(i + 2, col['Notes']  + 1).setValue(
        'Auto-closed: startup did not review within ' + REVIEW_CLOSE_DAYS + ' days.');
      SpreadsheetApp.flush();
      var body = '<p>Dear ' + sName + ', your application to <strong>' + stName
        + '</strong> has been closed as the startup did not review it within '
        + REVIEW_CLOSE_DAYS + ' days. You are free to apply to other openings.</p>';
      var instE = String(row[col['Institute_Email']] || '');
      var persE = String(row[col['Personal_Email']]  || '');
      sendEmail_(instE, 'Application closed -- ' + stName, body);
      if (persE !== instE) sendEmail_(persE, 'Application closed -- ' + stName, body);
    }
  });
}

// Shortlisted but no interview scheduled -- nudge or auto-close
function checkScheduleSLA_() {
  var sheet = sh_('APPLICATIONS');
  if (!sheet || sheet.getLastRow() < 2) return;
  var data  = sheet.getDataRange().getValues();
  var heads = data[0];
  var col   = cols_(heads);
  var now   = Date.now();

  data.slice(1).forEach(function(row, i) {
    if (String(row[col['Status']] || '') !== 'Shortlisted') return;
    var shAt = new Date(String(row[col['Shortlisted_At']] || '')).getTime();
    if (!shAt || isNaN(shAt)) return;
    var daysOld  = (now - shAt) / 86400000;
    var startupId= String(row[col['Startup_ID']]  || '');
    var appId    = String(row[col['App_ID']]       || '');
    var sName    = String(row[col['Student_Name']] || '');
    var stName   = String(row[col['Startup_Name']] || '');

    if (Math.floor(daysOld) === SCHEDULE_SLA_DAYS) {
      notifyStartup_(startupId,
        '[CTIE SLA] Interview not scheduled for ' + sName,
        sName + ' was shortlisted ' + SCHEDULE_SLA_DAYS
        + ' days ago. Please schedule the interview. Auto-close at day '
        + SCHEDULE_CLOSE_DAYS + '.');
    }
    if (daysOld >= SCHEDULE_CLOSE_DAYS) {
      sheet.getRange(i + 2, col['Status'] + 1).setValue('Closed -- Not Scheduled');
      sheet.getRange(i + 2, col['Notes']  + 1).setValue(
        'Auto-closed: startup did not schedule interview within ' + SCHEDULE_CLOSE_DAYS + ' days.');
      SpreadsheetApp.flush();
      var instE = String(row[col['Institute_Email']] || '');
      var persE = String(row[col['Personal_Email']]  || '');
      var body  = '<p>Dear ' + sName + ', the startup did not schedule your interview within '
        + SCHEDULE_CLOSE_DAYS + ' days. Your application has been closed. '
        + 'You are free to apply to other openings.</p>';
      sendEmail_(instE, 'Application closed -- ' + stName, body);
      if (persE !== instE) sendEmail_(persE, 'Application closed -- ' + stName, body);
      sendEmail_(ADMIN_EMAIL,
        '[CTIE SLA] Auto-closed (no schedule): ' + appId,
        stName + ' did not schedule interview for ' + sName + ' within '
        + SCHEDULE_CLOSE_DAYS + ' days.');
    }
  });
}

// Interview past -- startup has not entered outcome
function checkOutcomeSLA_() {
  var sheet = sh_('APPLICATIONS');
  if (!sheet || sheet.getLastRow() < 2) return;
  var data  = sheet.getDataRange().getValues();
  var heads = data[0];
  var col   = cols_(heads);
  var now   = Date.now();

  data.slice(1).forEach(function(row, i) {
    var status = String(row[col['Status']] || '');
    if (status !== 'Interview Scheduled') return;

    var slot      = parseInt(row[col['Active_Interview_Slot']] || '1');
    // cellStr_(), not String() -- a scheduled interview's date/time cell is
    // often a real Date object (Sheets auto-converts the raw picker value),
    // and String(dateObj) produces "Fri Jul 17 2026 00:00:00 GMT+0530 ...",
    // which silently fails to parse below and makes this whole SLA check
    // skip every scheduled interview.
    var dateStr   = cellStr_(row[col['Interview_' + slot + '_Date']]) || '';
    var timeStr   = cellStr_(row[col['Interview_' + slot + '_Time']]) || '08:00';
    if (!dateStr) return;

    var intDt = new Date(dateStr + 'T' + (timeStr.length === 5 ? timeStr : '09:00'));
    if (isNaN(intDt.getTime()) || now < intDt.getTime()) return;

    var hoursElapsed = (now - intDt.getTime()) / 3600000;
    var startupId = String(row[col['Startup_ID']]   || '');
    var appId     = String(row[col['App_ID']]        || '');
    var sName     = String(row[col['Student_Name']]  || '');
    var stName    = String(row[col['Startup_Name']]  || '');
    var instE     = String(row[col['Institute_Email']] || '');
    var persE     = String(row[col['Personal_Email']]  || '');

    if (hoursElapsed >= OUTCOME_NUDGE_H && hoursElapsed < OUTCOME_NUDGE_H + 1) {
      notifyStartup_(startupId,
        '[CTIE] Please enter interview outcome for ' + sName,
        'It has been ' + OUTCOME_NUDGE_H + ' hours since the interview. '
        + 'Please log in and enter the outcome (Selected / Not Selected / Reschedule).');
    }

    if (hoursElapsed >= OUTCOME_URGENT_H && hoursElapsed < OUTCOME_URGENT_H + 1) {
      notifyStartup_(startupId,
        '[CTIE URGENT] Outcome overdue: ' + appId,
        OUTCOME_URGENT_H + ' hours have passed. ' + sName
        + ' is still waiting for your decision. Please enter outcome immediately.');
      // Update student-visible status
      sheet.getRange(i + 2, col['Status'] + 1)
        .setValue('Interview Held -- Outcome Pending');
      SpreadsheetApp.flush();
    }

    if (hoursElapsed >= OUTCOME_CLOSE_H) {
      sheet.getRange(i + 2, col['Status'] + 1).setValue('Closed -- No Outcome');
      sheet.getRange(i + 2, col['Notes']  + 1).setValue(
        'Auto-closed: startup did not enter outcome within ' + OUTCOME_CLOSE_H + ' hours.');
      SpreadsheetApp.flush();
      var body = '<p>Dear ' + sName + ', the startup did not provide feedback within '
        + OUTCOME_CLOSE_H + ' hours. Your application has been closed. '
        + 'You are free to apply to other openings on the portal.</p>';
      sendEmail_(instE, 'Application closed -- ' + stName, body);
      if (persE !== instE) sendEmail_(persE, 'Application closed -- ' + stName, body);
      sendEmail_(ADMIN_EMAIL,
        '[CTIE ALERT] No outcome ' + OUTCOME_CLOSE_H + 'h: ' + appId,
        stName + ' (' + startupId + ') did not enter outcome for ' + sName
        + ' after ' + OUTCOME_CLOSE_H + ' hours. Application auto-closed. '
        + 'Consider a conversation with this startup.');
    }
  });
}

