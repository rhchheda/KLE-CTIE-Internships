// Header colours
var HDR_BG = '#0B1F3A';
var HDR_FG = '#C8973A';

// Approximate column widths (pixels) per sheet
var COL_WIDTHS = {
  STARTUPS:    [130,180,200,80,80,100,120,80,300,220,220,150,200,120,60,140,140,80,80,100,220],
  INTERNSHIPS: [130,130,180,200,120,160,120,260,200,60,360,60,100,120,60,60,120,120,130,130,100,150,130,120,80,140,80,80,80],
  APPLICATIONS:[140,130,130,180,180,220,200,100,200,180,80,60,200,280,220,120,140,130,60,100,80,80,200,100,80,80,200,100,80,80,200,100,80,80,80,140,130,120,120,130,100,100,140,130,200,200,250,140,200,140],
  PROGRESS:    [120,140,140,130,50,140,80,80,280,280,60,280,140],
  CONFIG:      [220,280]
};

var APP_STATUSES = [
  'Applied','Shortlisted','Interview Scheduled',
  'Interview Held -- Outcome Pending','Offer Pending OTP',
  'Selected','Completed','Not Selected',
  'Closed -- Reschedule Limit','Closed -- No Response',
  'Closed -- Not Scheduled','Closed -- No Outcome'
];
var INT_STATUSES = ['Open','Full','Closed','Paused'];

function setupSheets() {
  var ss = SS_();

  Object.keys(SCHEMA).forEach(function(tabName) {
    var sh = ss.getSheetByName(tabName);
    if (!sh) {
      sh = ss.insertSheet(tabName);
    }

    // Always write / refresh header row
    var headers = SCHEMA[tabName];
    sh.getRange(1,1,1,headers.length).setValues([headers]);

    // Format header row
    var hdr = sh.getRange(1,1,1,headers.length);
    hdr.setBackground(HDR_BG)
       .setFontColor(HDR_FG)
       .setFontWeight('bold')
       .setFontSize(10)
       .setFontFamily('Arial')
       .setVerticalAlignment('middle')
       .setWrap(false);
    sh.setRowHeight(1, 32);
    sh.setFrozenRows(1);

    // Column widths
    var widths = COL_WIDTHS[tabName] || [];
    for (var ci = 0; ci < headers.length; ci++) {
      try { sh.setColumnWidth(ci+1, widths[ci]||120); } catch(e){}
    }

    // Data validation on Status column
    if (tabName !== 'CONFIG') {
      var statusIdx = headers.indexOf('Status');
      if (statusIdx >= 0) {
        var statList = (tabName==='INTERNSHIPS') ? INT_STATUSES : APP_STATUSES;
        var rule = SpreadsheetApp.newDataValidation()
          .requireValueInList(statList, true)
          .setAllowInvalid(true)
          .build();
        var maxRows = Math.max(sh.getMaxRows()-1, 200);
        sh.getRange(2, statusIdx+1, maxRows, 1).setDataValidation(rule);
      }

      // Alternating row shading via conditional format
      sh.clearConditionalFormatRules();
      var stripe = SpreadsheetApp.newConditionalFormatRule()
        .whenFormulaSatisfied('=ISEVEN(ROW())')
        .setBackground('#F8F9FA')
        .setRanges([sh.getRange(2,1,Math.min(sh.getMaxRows()-1,500), headers.length)])
        .build();
      sh.setConditionalFormatRules([stripe]);
    }

    // Lock the tab against direct manual editing. All real reads/writes go
    // through this script (running as the sheet owner, who Google always
    // exempts from a protection's editor list) -- a human editing cells by
    // hand bypasses validation, SLA timers, and hashing, and can silently
    // corrupt data the app assumes is well-formed.
    try {
      var existingProtections = sh.getProtections(SpreadsheetApp.ProtectionType.SHEET);
      existingProtections.forEach(function(p) { p.remove(); });
      var protection = sh.protect()
        .setDescription(tabName + ' -- managed by the Internship Portal script. Edit through the portal, not this sheet directly.');
      protection.removeEditors(protection.getEditors());
      if (protection.canDomainEdit()) protection.setDomainEdit(false);
    } catch(e) {
      Logger.log('Could not protect ' + tabName + ': ' + e.message);
    }

    Logger.log('Sheet ready: ' + tabName + ' (' + headers.length + ' cols)');
  });

  // CONFIG defaults
  var cfg = sh_('CONFIG');
  if (cfg.getLastRow() < 2) {
    var defaults = [
      ['max_reschedules',          String(MAX_RESCHEDULES)],
      ['review_sla_days',          String(REVIEW_SLA_DAYS)],
      ['review_close_days',        String(REVIEW_CLOSE_DAYS)],
      ['schedule_sla_days',        String(SCHEDULE_SLA_DAYS)],
      ['outcome_nudge_h',          String(OUTCOME_NUDGE_H)],
      ['outcome_urgent_h',         String(OUTCOME_URGENT_H)],
      ['outcome_close_h',          String(OUTCOME_CLOSE_H)],
      ['otp_minutes',              String(OTP_MINUTES)],
      ['default_duration_weeks',   '12'],
      ['min_application_days',     '14'],
      ['max_application_days',     '60'],
      ['default_internship_weeks', '12'],
      // Certificate eligibility -- defaults, not audited standards. Tune
      // freely; nothing about these two numbers is hardcoded in the script.
      ['min_weeks_logged_pct',     '70'],
      ['min_attendance_pct',       '75'],
      ['initialized',              now_()],
      ['version',                  '1.0'],
    ];
    defaults.forEach(function(row) { cfg.appendRow(row); });
  }

  // DEPARTMENTS -- reference sheet, deliberately outside SCHEMA/protection.
  // Institute + Department reporting needs structured values instead of the
  // free-typed Institute_Name/Course an applicant types today -- but this
  // list also needs to grow the moment a new branch or partner college
  // shows up, with no code change or redeploy. So unlike every other tab,
  // this one stays open for direct hand-editing in the Sheet: add a row,
  // it's live on the next page load (cached at most ~60s).
  var DEPT_HEADERS = ['Institute_Name', 'Department_Name', 'HoD_Name', 'HoD_Email', 'Active'];
  var deptSheet = ss.getSheetByName('DEPARTMENTS');
  if (!deptSheet) {
    deptSheet = ss.insertSheet('DEPARTMENTS');
    deptSheet.getRange(1,1,1,DEPT_HEADERS.length).setValues([DEPT_HEADERS]);
    var deptHdr = deptSheet.getRange(1,1,1,DEPT_HEADERS.length);
    deptHdr.setBackground(HDR_BG).setFontColor(HDR_FG).setFontWeight('bold')
      .setFontSize(10).setFontFamily('Arial').setVerticalAlignment('middle');
    deptSheet.setRowHeight(1, 32);
    deptSheet.setFrozenRows(1);
    var deptWidths = [220, 220, 160, 220, 80];
    for (var di = 0; di < DEPT_HEADERS.length; di++) {
      try { deptSheet.setColumnWidth(di+1, deptWidths[di]||150); } catch(e){}
    }
    // Inactive placeholder -- replace with real institutes/departments/HoDs.
    // Kept Active=FALSE so it never shows up as a real option until edited.
    deptSheet.appendRow(['KLE Technological University', 'SAMPLE -- replace with a real department', '', '', 'FALSE']);
    Logger.log('DEPARTMENTS sheet created -- add real institutes/departments/HoD emails before relying on it.');
  }

  SpreadsheetApp.flush();
  Logger.log('setupSheets complete');
  return { ok:true, msg:'All 5 sheets created, formatted, and frozen, plus the DEPARTMENTS reference tab.' };
}

