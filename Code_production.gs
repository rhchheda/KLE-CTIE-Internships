function findApp_(appId) {
  var sheet = sh_('APPLICATIONS');
  if (!sheet || sheet.getLastRow() < 2) return null;
  var data  = sheet.getDataRange().getValues();
  var heads = data[0];
  var col   = cols_(heads);
  for (var i = 1; i < data.length; i++) {
    if (String(data[i][col['App_ID']] || '') === appId)
      return { sheet: sheet, data: data[i], col: col, rowNum: i + 1 };
  }
  return null;
}

// Write multiple fields to an application row atomically
function updateAppFields_(row, fields) {
  Object.keys(fields).forEach(function(field) {
    if (row.col[field] === undefined) return;
    row.sheet.getRange(row.rowNum, row.col[field] + 1).setValue(fields[field]);
  });
  SpreadsheetApp.flush();
}

function getStartupRow_(startupId) {
  var sheet = sh_('STARTUPS');
  if (!sheet) return null;
  var data  = sheet.getDataRange().getValues();
